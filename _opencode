# MCP subcommand
_opencode_mcp() {
  local curcontext="$curcontext" state line
  local -A opt_args

  _arguments -C \
    '-h[Show help]' \
    '--help[Show help]' \
    '--print-logs[Print logs to stderr]' \
    '--log-level=[Log level]:log level:(DEBUG INFO WARN ERROR)' \
    '--pure[Run without external plugins]' \
    '1: :_opencode_mcp_commands' \
    '*:: :->args'

  case "$state" in
    args)
      case "$line[1]" in
        auth|logout|debug)
          _arguments \
            '-h[Show help]' \
            '--help[Show help]' \
            '--print-logs[Print logs to stderr]' \
            '--log-level=[Log level]:log level:(DEBUG INFO WARN ERROR)' \
            '--pure[Run without external plugins]' \
            '1:server:_opencode_mcp_servers'
          ;;
        *)
          _arguments \
            '-h[Show help]' \
            '--help[Show help]' \
            '--print-logs[Print logs to stderr]' \
            '--log-level=[Log level]:log level:(DEBUG INFO WARN ERROR)' \
            '--pure[Run without external plugins]'
          ;;
      esac
      ;;
  esac
}

